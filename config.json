      "s": { "type": "strobe", "speed_index": 2, "label": "Strobe 3" },
      "d": { "type": "chase",  "speed_index": 0, "label": "Chase 1" },
      "f": { "type": "chase",  "speed_index": 1, "label": "Chase 2" },
      "g": { "type": "chase",  "speed_index": 2, "label": "Chase 3" }
